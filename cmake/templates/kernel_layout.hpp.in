constexpr uint64_t kKernelReservedPhysicalBytes = @OS1_KERNEL_RESERVED_PHYSICAL_BYTES@;
constexpr uint64_t kKernelReservedPhysicalEnd = @OS1_KERNEL_RESERVED_PHYSICAL_END@;
constexpr uint64_t kKernelPostImageReserveBytes = @OS1_KERNEL_POST_IMAGE_RESERVE_BYTES@;